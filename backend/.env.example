# Copy to backend/.env (this file lives next to the Nest app).

USE_IN_MEMORY_DB=0

# HTTP port (default 3000). Set when 3000 is already in use.
# PORT=3001
# If PORT is not 3000, set the same origin in frontend/.env as VITE_API_URL (see frontend/.env.example).

# Optional: absolute path for admin product image uploads (default: ../frontend/public/products from repo root)
# PRODUCT_IMAGE_UPLOAD_DIR=
# Optional: URL prefix returned for uploaded product images (default: /products)
# PRODUCT_IMAGE_BASE_URL=
# Extra allowed browser origins (comma-separated), e.g. http://192.168.1.5:5173
# CORS_ORIGIN=

# Rate limiting (enabled by default in production only).
# Set RATE_LIMIT_ENABLED=0 to disable in any environment.
# RATE_LIMIT_TTL_MS=60000
# RATE_LIMIT_MAX=120
# RATE_LIMIT_ENABLED=0

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=golf_ecommerce

# Comma-separated list of admin emails (matched at signup time)
ADMIN_EMAILS=admin@golflinks.local

# Optional: enable LLM-backed AI assistant answers (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Product-page "Ask ChatGPT" modal: prefers OpenAI ChatGPT when set; otherwise uses GEMINI_API_KEY (same as shopping assistant).
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
